{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "^db:generate",
        "build:styles",
        "build:components"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "src"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist"
      ],
      "env": [
        "DATABASE_URL",
        "JWT_SECRET"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "build:styles": {
      "outputs": [
        "dist/**"
      ]
    },
    "build:components": {
      "outputs": [
        "dist/**"
      ]
    },
    "dev:styles": {
      "cache": false,
      "persistent": true
    },
    "dev:components": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "with": [
        "dev:styles",
        "dev:components"
      ]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    }
  }
}